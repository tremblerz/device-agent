{
  "name": "device-agent-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "On-device LLM agent harness for React Native, plus a demo app.",
  "workspaces": [
    "packages/*",
    "example"
  ],
  "scripts": {
    "build": "npm run build --workspace packages/react-native-device-agent",
    "typecheck": "tsc -b",
    "example": "npm run --workspace example",
    "ios": "npm run --workspace example ios",
    "android": "npm run --workspace example android"
  },
  "engines": {
    "node": ">=20"
  }
}
